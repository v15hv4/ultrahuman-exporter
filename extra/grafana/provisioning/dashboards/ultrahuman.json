{
  "uid": "ultrahuman",
  "title": "Ultrahuman Health",
  "tags": ["ultrahuman", "health"],
  "timezone": "browser",
  "schemaVersion": 39,
  "refresh": "5m",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Recovery Index",
      "type": "stat",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${DS_VICTORIAMETRICS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "green", "value": 80 }
            ]
          },
          "max": 100,
          "min": 0,
          "unit": "percent"
        }
      },
      "options": { "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [{ "expr": "uh_recovery_index", "legendFormat": "Recovery" }]
    },
    {
      "id": 2,
      "title": "Sleep Efficiency",
      "type": "stat",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${DS_VICTORIAMETRICS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 75 },
              { "color": "green", "value": 85 }
            ]
          },
          "max": 100,
          "min": 0,
          "unit": "percent"
        }
      },
      "options": { "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [{ "expr": "uh_sleep_efficiency_percent", "legendFormat": "Efficiency" }]
    },
    {
      "id": 3,
      "title": "Morning Alertness",
      "type": "stat",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${DS_VICTORIAMETRICS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "green", "value": 80 }
            ]
          },
          "max": 100,
          "min": 0,
          "unit": "percent"
        }
      },
      "options": { "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [{ "expr": "uh_morning_alertness", "legendFormat": "Alertness" }]
    },
    {
      "id": 4,
      "title": "Resting Heart Rate",
      "type": "stat",
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${DS_VICTORIAMETRICS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 60 },
              { "color": "red", "value": 80 }
            ]
          },
          "unit": "bpm"
        }
      },
      "options": { "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [{ "expr": "uh_resting_heart_rate_bpm", "legendFormat": "RHR" }]
    },
    {
      "id": 5,
      "title": "Heart Rate",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_VICTORIAMETRICS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "bpm",
          "custom": { "drawStyle": "line", "lineWidth": 1, "fillOpacity": 10, "pointSize": 3, "showPoints": "auto" }
        }
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        { "expr": "uh_heart_rate_bpm", "legendFormat": "Heart Rate" },
        { "expr": "uh_resting_heart_rate_bpm", "legendFormat": "Resting HR" }
      ]
    },
    {
      "id": 6,
      "title": "Heart Rate Variability",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_VICTORIAMETRICS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "ms",
          "custom": { "drawStyle": "line", "lineWidth": 1, "fillOpacity": 10, "pointSize": 3, "showPoints": "auto" }
        }
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        { "expr": "uh_hrv_ms", "legendFormat": "HRV" },
        { "expr": "uh_avg_sleep_hrv_ms", "legendFormat": "Avg Sleep HRV" }
      ]
    },
    {
      "id": 7,
      "title": "Sleep Breakdown",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_VICTORIAMETRICS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "m",
          "custom": { "drawStyle": "bars", "lineWidth": 0, "fillOpacity": 80, "stacking": { "mode": "normal" } }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Deep" }, "properties": [{ "id": "color", "value": { "fixedColor": "dark-blue", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "Light" }, "properties": [{ "id": "color", "value": { "fixedColor": "light-blue", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "REM" }, "properties": [{ "id": "color", "value": { "fixedColor": "purple", "mode": "fixed" } }] }
        ]
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        { "expr": "uh_deep_sleep_minutes", "legendFormat": "Deep" },
        { "expr": "uh_light_sleep_minutes", "legendFormat": "Light" },
        { "expr": "uh_rem_sleep_minutes", "legendFormat": "REM" }
      ]
    },
    {
      "id": 8,
      "title": "Total Sleep",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_VICTORIAMETRICS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "blue", "mode": "fixed" },
          "unit": "m",
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 20, "pointSize": 5, "showPoints": "always" }
        }
      },
      "options": { "legend": { "displayMode": "hidden" } },
      "targets": [{ "expr": "uh_total_sleep_minutes", "legendFormat": "Total Sleep" }]
    },
    {
      "id": 9,
      "title": "Steps",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 20, "w": 8, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "${DS_VICTORIAMETRICS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "green", "mode": "fixed" },
          "unit": "short",
          "custom": { "drawStyle": "bars", "lineWidth": 0, "fillOpacity": 80 }
        }
      },
      "options": { "legend": { "displayMode": "hidden" } },
      "targets": [{ "expr": "increase(uh_steps_total[1d])", "legendFormat": "Steps" }]
    },
    {
      "id": 10,
      "title": "Active Minutes",
      "type": "timeseries",
      "gridPos": { "x": 8, "y": 20, "w": 8, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "${DS_VICTORIAMETRICS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "orange", "mode": "fixed" },
          "unit": "m",
          "custom": { "drawStyle": "bars", "lineWidth": 0, "fillOpacity": 80 }
        }
      },
      "options": { "legend": { "displayMode": "hidden" } },
      "targets": [{ "expr": "uh_active_minutes", "legendFormat": "Active" }]
    },
    {
      "id": 11,
      "title": "Movement Index",
      "type": "timeseries",
      "gridPos": { "x": 16, "y": 20, "w": 8, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "${DS_VICTORIAMETRICS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "yellow", "mode": "fixed" },
          "unit": "short",
          "custom": { "drawStyle": "line", "lineWidth": 1, "fillOpacity": 20, "pointSize": 3, "showPoints": "auto" }
        }
      },
      "options": { "legend": { "displayMode": "hidden" } },
      "targets": [{ "expr": "uh_movement_index", "legendFormat": "Movement Index" }]
    },
    {
      "id": 12,
      "title": "SpO2",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 26, "w": 12, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "${DS_VICTORIAMETRICS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 90 },
              { "color": "green", "value": 95 }
            ]
          },
          "unit": "percent",
          "min": 80,
          "max": 100,
          "custom": { "drawStyle": "line", "lineWidth": 1, "fillOpacity": 20, "pointSize": 3, "showPoints": "auto" }
        }
      },
      "options": { "legend": { "displayMode": "hidden" } },
      "targets": [{ "expr": "uh_spo2_percent", "legendFormat": "SpO2" }]
    },
    {
      "id": 13,
      "title": "Skin Temperature",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 26, "w": 12, "h": 6 },
      "datasource": { "type": "prometheus", "uid": "${DS_VICTORIAMETRICS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "red", "mode": "fixed" },
          "unit": "celsius",
          "custom": { "drawStyle": "line", "lineWidth": 1, "fillOpacity": 20, "pointSize": 3, "showPoints": "auto" }
        }
      },
      "options": { "legend": { "displayMode": "hidden" } },
      "targets": [{ "expr": "uh_skin_temperature_celsius", "legendFormat": "Temp" }]
    },
    {
      "id": 14,
      "title": "Exporter: API Requests",
      "type": "stat",
      "gridPos": { "x": 0, "y": 32, "w": 6, "h": 3 },
      "datasource": { "type": "prometheus", "uid": "${DS_VICTORIAMETRICS}" },
      "fieldConfig": { "defaults": { "unit": "short" } },
      "options": { "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [{ "expr": "uhex_api_requests_total", "legendFormat": "Requests" }]
    },
    {
      "id": 15,
      "title": "Exporter: Metrics Exported",
      "type": "stat",
      "gridPos": { "x": 6, "y": 32, "w": 6, "h": 3 },
      "datasource": { "type": "prometheus", "uid": "${DS_VICTORIAMETRICS}" },
      "fieldConfig": { "defaults": { "unit": "short" } },
      "options": { "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [{ "expr": "uhex_metrics_exported_total", "legendFormat": "Exported" }]
    },
    {
      "id": 16,
      "title": "Exporter: Last Success",
      "type": "stat",
      "gridPos": { "x": 12, "y": 32, "w": 6, "h": 3 },
      "datasource": { "type": "prometheus", "uid": "${DS_VICTORIAMETRICS}" },
      "fieldConfig": { "defaults": { "unit": "dateTimeFromNow" } },
      "options": { "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [{ "expr": "uhex_last_success_timestamp * 1000", "legendFormat": "Last Success" }]
    },
    {
      "id": 17,
      "title": "Exporter: Errors",
      "type": "stat",
      "gridPos": { "x": 18, "y": 32, "w": 6, "h": 3 },
      "datasource": { "type": "prometheus", "uid": "${DS_VICTORIAMETRICS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        }
      },
      "options": { "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [{ "expr": "uhex_errors_total", "legendFormat": "Errors" }]
    }
  ],
  "templating": {
    "list": [
      {
        "name": "DS_VICTORIAMETRICS",
        "type": "datasource",
        "query": "prometheus",
        "current": { "selected": true, "text": "VictoriaMetrics", "value": "VictoriaMetrics" },
        "hide": 2
      }
    ]
  }
}
